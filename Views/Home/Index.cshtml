        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="cpm-card p-4 h-100 text-center">
                    <i class="bi bi-shield-check"></i>
                    <h5 class="fw-bold mt-3">@C("home.trust.card1.title", "Profissionais verificados")</h5>
                    <p class="mb-0">@C("home.trust.card1.description", "Analisamos dados e documentos antes da ativacao no portal.")</p>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="cpm-card p-4 h-100 text-center">
                    <i class="bi bi-star-fill"></i>
                    <h5 class="fw-bold mt-3">@C("home.trust.card2.title", "Avaliacoes reais")</h5>
                    <p class="mb-0">@C("home.trust.card2.description", "Consulte opinioes de clientes para escolher com mais seguranca.")</p>
                </div>
