@model HomePageViewModel
@{
    string C(string key, string fallback) => SiteContent.Get(key, fallback);

    var pageTitle = C("home.meta.title", "Resolva os problemas da sua casa");
    ViewData["Title"] = pageTitle;
    ViewData["SeoTitle"] = C("home.meta.seo_title", pageTitle);
    ViewData["MetaDescription"] = C("home.meta.description", "Solicite servicos residenciais no ConsertaPraMim e encontre eletricista, encanador, pintor e outros profissionais perto de voce.");
    ViewData["MetaKeywords"] = C("home.meta.keywords", "servicos residenciais, eletricista, encanador, pedreiro, pintor, conserto casa");
    ViewData["CanonicalPath"] = "/";
    ViewData["OgImage"] = C("home.meta.og_image_url", C("branding.og_image_url", Url.Content("~/images/7237a130-fa5b-4e98-9118-ed5b0d465fa6.png")));
}

<section class="cpm-hero">
    <div class="container-lg text-center">
        <h1 class="display-5 fw-bold mb-3">@C("home.hero.title", "Resolva os problemas da sua casa")</h1>
        <p class="lead text-white-50 mx-auto mb-4" style="max-width: 760px;">
            @C("home.hero.subtitle", "Encontre eletricistas, encanadores, pedreiros e outros especialistas em minutos, com atendimento proximo de voce.")
        </p>
        <form class="row g-2 justify-content-center" asp-controller="Home" asp-action="RequestService" method="get">
            <div class="col-12 col-md-4">
                <input type="text" name="description" class="form-control form-control-lg" placeholder="@C("home.hero.form.description_placeholder", "Descreva o servico desejado")" />
            </div>
            <div class="col-12 col-md-3">
                <div class="input-group input-group-lg cpm-location-group">
                    <input
                        id="homeLocationInput"
                        type="text"
                        name="location"
                        class="form-control"
                        placeholder="@C("home.hero.form.location_placeholder", "Digite seu CEP")"
                        autocomplete="postal-code"
                        inputmode="numeric"
                        pattern="[0-9]{5}-?[0-9]{3}"
                        maxlength="9" />
                    <button
                        id="getUserLocationBtn"
                        type="button"
                        class="btn cpm-location-btn"
                        aria-label="@C("home.hero.form.location_button_aria", "Usar minha localizacao")"
                        title="@C("home.hero.form.location_button_title", "Usar minha localizacao")">
                        <i class="bi bi-geo-alt-fill"></i>
                    </button>
                </div>
                <div id="homeLocationFeedback" class="cpm-location-feedback d-none"></div>
            </div>
            <div class="col-12 col-md-auto d-grid">
                <button type="submit" class="btn cpm-btn-primary btn-lg px-4">@C("home.hero.form.submit", "Encontrar profissionais")</button>
            </div>
        </form>
    </div>
</section>

<section class="cpm-section bg-white cpm-top-services">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">@C("home.topservices.title", "Servicos mais buscados")</h2>
            <p class="text-secondary-emphasis mb-0">@C("home.topservices.subtitle", "Escolha a categoria e receba orcamentos rapidamente")</p>
        </div>
        <div class="row g-3 justify-content-center">
            @foreach (var category in Model.Categories)
            {
                <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                    <a class="cpm-category-card" data-equalize-item="top-services" asp-controller="Home" asp-action="RequestService" asp-route-categoryId="@category.Id">
                        <span class="cpm-category-icon"><i class="bi @category.IconClass"></i></span>
                        <span class="fw-semibold">@category.Name</span>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section class="cpm-section">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">@C("home.about.title", "Sobre a ConsertaPraMim")</h2>
            <p class="text-secondary-emphasis mb-0">
                @C("home.about.subtitle", "Somos uma plataforma digital que conecta clientes e prestadores locais para servicos domesticos, manutencao, instalacoes e reformas.")
            </p>
        </div>

        <div class="row g-4 align-items-stretch">
            <div class="col-12 col-lg-6">
                <div class="cpm-card h-100 p-4">
                    <h5 class="fw-bold mb-3">@C("home.about.proposal.title", "Nossa proposta")</h5>
                    <p class="text-secondary-emphasis mb-3">
                        @C("home.about.proposal.paragraph1", "A ConsertaPraMim nasceu para simplificar a contratacao de servicos e fortalecer profissionais da propria regiao. A operacao inicial comeca em Praia Grande, com foco em qualidade, organizacao e comunicacao clara.")
                    </p>
                    <p class="text-secondary-emphasis mb-0">
                        @C("home.about.proposal.paragraph2", "Aqui, cliente e profissional conversam de forma direta, recebem e enviam orcamentos com agilidade e acompanham o atendimento com mais transparencia.")
                    </p>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="cpm-card h-100 p-4">
                    <h5 class="fw-bold mb-3">@C("home.about.differentials.title", "Diferenciais da plataforma")</h5>
                    <div class="row g-2">
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item1", "Prestadores locais")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item2", "Comunicacao direta")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item3", "Orcamento rapido")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item4", "Agendamento simples")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item5", "Contato via WhatsApp")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item6", "Avaliacao mutua")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item7", "Painel de acompanhamento")</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">@C("home.about.differentials.item8", "Equipe de suporte")</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cpm-section">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">@C("home.howitworks.title", "Como funciona")</h2>
            <p class="text-secondary-emphasis mb-0">@C("home.howitworks.subtitle", "Fluxo completo da solicitacao ate a avaliacao final")</p>
        </div>
        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">1</div>
                <h5 class="fw-bold">@C("home.howitworks.step1.title", "Cliente solicita o servico")</h5>
                <p class="text-secondary-emphasis mb-0">@C("home.howitworks.step1.description", "O cliente descreve o problema e informa a localizacao.")</p>
            </div>
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
