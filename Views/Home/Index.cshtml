@model HomePageViewModel
@{
    ViewData["Title"] = "Resolva os problemas da sua casa";
    ViewData["SeoTitle"] = "Resolva os problemas da sua casa";
    ViewData["MetaDescription"] = "Solicite servicos residenciais no ConsertaPraMim e encontre eletricista, encanador, pintor e outros profissionais perto de voce.";
    ViewData["MetaKeywords"] = "servicos residenciais, eletricista, encanador, pedreiro, pintor, conserto casa";
    ViewData["CanonicalPath"] = "/";
    ViewData["OgImage"] = Url.Content("~/images/7237a130-fa5b-4e98-9118-ed5b0d465fa6.png");
}

<section class="cpm-hero">
    <div class="container-lg text-center">
        <h1 class="display-5 fw-bold mb-3">@Model.Content("home.hero.title", "Resolva os problemas da sua casa")</h1>
        <p class="lead text-white-50 mx-auto mb-4" style="max-width: 760px;">
            @Model.Content("home.hero.subtitle", "Encontre eletricistas, encanadores, pedreiros e outros especialistas em minutos, com atendimento proximo de voce.")
        </p>
        <form class="row g-2 justify-content-center" asp-controller="Home" asp-action="RequestService" method="get">
            <div class="col-12 col-md-4">
                <input type="text" name="description" class="form-control form-control-lg" placeholder="Descreva o servico desejado" />
            </div>
            <div class="col-12 col-md-3">
                <div class="input-group input-group-lg cpm-location-group">
                    <input
                        id="homeLocationInput"
                        type="text"
                        name="location"
                        class="form-control"
                        placeholder="Digite seu CEP"
                        autocomplete="postal-code"
                        inputmode="numeric"
                        pattern="[0-9]{5}-?[0-9]{3}"
                        maxlength="9" />
                    <button
                        id="getUserLocationBtn"
                        type="button"
                        class="btn cpm-location-btn"
                        aria-label="Usar minha localizacao"
                        title="Usar minha localizacao">
                        <i class="bi bi-geo-alt-fill"></i>
                    </button>
                </div>
                <div id="homeLocationFeedback" class="cpm-location-feedback d-none"></div>
            </div>
            <div class="col-12 col-md-auto d-grid">
                <button type="submit" class="btn cpm-btn-primary btn-lg px-4">Encontrar profissionais</button>
            </div>
        </form>
    </div>
</section>

<section class="cpm-section bg-white">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">@Model.Content("home.topservices.title", "Servicos mais buscados")</h2>
            <p class="text-secondary-emphasis mb-0">@Model.Content("home.topservices.subtitle", "Escolha a categoria e receba orcamentos rapidamente")</p>
        </div>
        <div class="row g-3 justify-content-center">
            @foreach (var category in Model.Categories)
            {
                <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                    <a class="cpm-category-card" asp-controller="Home" asp-action="RequestService" asp-route-categoryId="@category.Id">
                        <span class="cpm-category-icon"><i class="bi @category.IconClass"></i></span>
                        <span class="fw-semibold">@category.Name</span>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section class="cpm-section">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">@Model.Content("home.about.title", "Sobre a ConsertaPraMim")</h2>
            <p class="text-secondary-emphasis mb-0">
                @Model.Content("home.about.subtitle", "Somos uma plataforma digital que conecta clientes e prestadores locais para servicos domesticos, manutencao, instalacoes e reformas.")
            </p>
        </div>

        <div class="row g-4 align-items-stretch">
            <div class="col-12 col-lg-6">
                <div class="cpm-card h-100 p-4">
                    <h5 class="fw-bold mb-3">@Model.Content("home.about.proposal.title", "Nossa proposta")</h5>
                    <p class="text-secondary-emphasis mb-3">
                        @Model.Content("home.about.proposal.paragraph1", "A ConsertaPraMim nasceu para simplificar a contratacao de servicos e fortalecer profissionais da propria regiao. A operacao inicial comeca em Praia Grande, com foco em qualidade, organizacao e comunicacao clara.")
                    </p>
                    <p class="text-secondary-emphasis mb-0">
                        @Model.Content("home.about.proposal.paragraph2", "Aqui, cliente e profissional conversam de forma direta, recebem e enviam orcamentos com agilidade e acompanham o atendimento com mais transparencia.")
                    </p>
                </div>
            </div>
            <div class="col-12 col-lg-6">
                <div class="cpm-card h-100 p-4">
                    <h5 class="fw-bold mb-3">@Model.Content("home.about.differentials.title", "Diferenciais da plataforma")</h5>
                    <div class="row g-2">
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Prestadores locais</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Comunicacao direta</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Orcamento rapido</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Agendamento simples</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Contato via WhatsApp</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Avaliacao mutua</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Painel de acompanhamento</span></div>
                        <div class="col-12 col-sm-6"><span class="cpm-badge d-inline-flex py-2 px-3">Equipe de suporte</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cpm-section">
    <div class="container-lg">
        <div class="text-center mb-5">
            <h2 class="fw-bold">@Model.Content("home.howitworks.title", "Como funciona")</h2>
            <p class="text-secondary-emphasis mb-0">@Model.Content("home.howitworks.subtitle", "Fluxo completo da solicitacao ate a avaliacao final")</p>
        </div>
        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">1</div>
                <h5 class="fw-bold">Cliente solicita o servico</h5>
                <p class="text-secondary-emphasis mb-0">O cliente descreve o problema e informa a localizacao.</p>
            </div>
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">2</div>
                <h5 class="fw-bold">Prestadores recebem o pedido</h5>
                <p class="text-secondary-emphasis mb-0">Profissionais da regiao visualizam a oportunidade de atendimento.</p>
            </div>
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">3</div>
                <h5 class="fw-bold">Profissional envia orcamento</h5>
                <p class="text-secondary-emphasis mb-0">Cada prestador interessado pode enviar sua proposta.</p>
            </div>
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">4</div>
                <h5 class="fw-bold">Cliente conversa diretamente</h5>
                <p class="text-secondary-emphasis mb-0">As partes alinham detalhes, prazo, valor e agendamento.</p>
            </div>
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">5</div>
                <h5 class="fw-bold">Servico e realizado</h5>
                <p class="text-secondary-emphasis mb-0">O profissional executa o trabalho conforme o combinado.</p>
            </div>
            <div class="col-12 col-md-6 col-lg-4 cpm-step">
                <div class="cpm-step-number">6</div>
                <h5 class="fw-bold">Ambos avaliam o atendimento</h5>
                <p class="text-secondary-emphasis mb-0">As avaliacoes ajudam a manter confianca e qualidade na plataforma.</p>
            </div>
        </div>
    </div>
</section>

<section class="cpm-section cpm-trust">
    <div class="container-lg">
        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="cpm-card p-4 h-100 text-center">
                    <i class="bi bi-shield-check"></i>
                    <h5 class="fw-bold mt-3">Profissionais verificados</h5>
                    <p class="mb-0">Analisamos dados e documentos antes da ativacao no portal.</p>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="cpm-card p-4 h-100 text-center">
                    <i class="bi bi-star-fill"></i>
                    <h5 class="fw-bold mt-3">Avaliacoes reais</h5>
                    <p class="mb-0">Consulte opinioes de clientes para escolher com mais seguranca.</p>
                </div>
            </div>
            <div class="col-12 col-md-4">
                <div class="cpm-card p-4 h-100 text-center">
                    <i class="bi bi-people-fill"></i>
                    <h5 class="fw-bold mt-3">Suporte humano</h5>
                    <p class="mb-0">Nossa equipe acompanha voce durante toda a jornada.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="cpm-section cpm-professional-cta">
    <div class="container-lg">
        <div class="row align-items-center g-4">
            <div class="col-12 col-lg-7">
                <h2 class="fw-bold">@Model.Content("home.procta.title", "Voce e profissional?")</h2>
                <p class="text-secondary-emphasis">
                    @Model.Content("home.procta.subtitle", "Cadastre-se no ConsertaPraMim e receba novas oportunidades todos os dias na sua cidade.")
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn cpm-btn-primary" asp-controller="Home" asp-action="RegisterProfessional">Quero me cadastrar</a>
                    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="RegisterProfessional">Saiba mais</a>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <img src="~/images/7237a130-fa5b-4e98-9118-ed5b0d465fa6.png" asp-append-version="true" alt="Profissional trabalhando" class="img-fluid rounded-4 shadow" />
            </div>
        </div>
    </div>
</section>

<section class="py-5 text-center" style="background: var(--cpm-primary); color: #fff;">
    <div class="container-lg py-4">
        <h2 class="fw-bold mb-3">@Model.Content("home.finalcta.title", "Pronto para resolver seu problema?")</h2>
        <p class="mb-4">@Model.Content("home.finalcta.subtitle", "Solicite agora e receba contatos de profissionais proximos.")</p>
        <a class="btn btn-dark btn-lg" asp-controller="Home" asp-action="RequestService">Solicitar servico agora</a>
    </div>
</section>

@section Head {
    @{
        var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
        var itemListElements = Model.Categories
            .Select((category, idx) => new Dictionary<string, object?>
            {
                ["@type"] = "ListItem",
                ["position"] = idx + 1,
                ["name"] = category.Name,
                ["url"] = $"{baseUrl}/solicitar-servico?categoryId={category.Id}"
            })
            .ToList();

        var structuredData = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "WebPage",
                ["name"] = "Resolva os problemas da sua casa",
                ["description"] = "Solicite servicos residenciais no ConsertaPraMim e encontre profissionais perto de voce.",
                ["url"] = $"{baseUrl}/",
                ["inLanguage"] = "pt-BR"
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "ItemList",
                ["name"] = "Servicos mais buscados",
                ["itemListElement"] = itemListElements
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "HowTo",
                ["name"] = "Como funciona a plataforma ConsertaPraMim",
                ["step"] = new object[]
                {
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = "Cliente solicita o servico", ["text"] = "Descreva o problema e informe seu CEP." },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = "Prestadores recebem o pedido", ["text"] = "Profissionais da regiao visualizam sua solicitacao." },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = "Profissional envia orcamento", ["text"] = "Os interessados retornam com proposta e prazo." },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = "Cliente conversa e fecha", ["text"] = "Cliente e profissional alinham valor e agendamento." },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = "Servico concluido e avaliado", ["text"] = "Apos o atendimento, ambos podem avaliar a experiencia." }
                }
            }
        };
    }
    <script type="application/ld+json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(structuredData))</script>
}

@section Scripts {
    <script>
        (() => {
            const locationInput = document.getElementById("homeLocationInput");
            const locationButton = document.getElementById("getUserLocationBtn");
            const feedback = document.getElementById("homeLocationFeedback");

            if (!locationInput || !locationButton || !feedback || !window.CepResolver) {
                return;
            }

            const cepLookup = window.CepResolver.bindCepLookup({
                input: locationInput,
                feedback: feedback,
                messages: {
                    loading: "Consultando CEP...",
                    resolved: (addressText) => `Endereco do CEP: ${addressText}`,
                    unresolved: "Nao foi possivel resolver rua, bairro, cidade e UF. O CEP digitado sera aceito."
                }
            });

            const reverseGeocodeToCep = async (lat, lon) => {
                const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}`;
                const response = await fetch(url);
                if (!response.ok) {
                    throw new Error("reverse-geocode-failed");
                }

                const data = await response.json();
                const cepDigits = window.CepResolver.onlyDigits(data?.address?.postcode ?? "").slice(0, 8);
                return cepDigits.length === 8 ? cepDigits : null;
            };

            locationButton.addEventListener("click", () => {
                if (!navigator.geolocation) {
                    cepLookup.setFeedback("error", "Seu navegador nao suporta geolocalizacao.");
                    return;
                }

                locationButton.disabled = true;
                cepLookup.setFeedback("", "Obtendo sua localizacao...");

                navigator.geolocation.getCurrentPosition(
                    async (position) => {
                        const latitude = position.coords.latitude.toFixed(6);
                        const longitude = position.coords.longitude.toFixed(6);

                        try {
                            const cepDigits = await reverseGeocodeToCep(latitude, longitude);
                            if (!cepDigits) {
                                cepLookup.setFeedback("warning", "Nao foi possivel identificar o CEP automaticamente.");
                            } else {
                                locationInput.value = window.CepResolver.formatCep(cepDigits);
                                await cepLookup.lookupCurrent();
                            }
                        } catch {
                            cepLookup.setFeedback("warning", "Nao foi possivel converter sua localizacao em CEP.");
                        } finally {
                            locationButton.disabled = false;
                        }
                    },
                    (error) => {
                        let message = "Nao foi possivel obter sua localizacao.";

                        if (error.code === 1) {
                            message = "Permissao negada para acessar sua localizacao.";
                        } else if (error.code === 2) {
                            message = "Localizacao indisponivel no momento.";
                        } else if (error.code === 3) {
                            message = "Tempo excedido ao buscar sua localizacao.";
                        }

                        cepLookup.setFeedback("error", message);
                        locationButton.disabled = false;
                    },
                    {
                        enableHighAccuracy: true,
                        timeout: 10000,
                        maximumAge: 60000
                    });
            });
        })();
    </script>
}
