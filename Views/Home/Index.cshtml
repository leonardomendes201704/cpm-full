<section class="cpm-section cpm-professional-cta">
    <div class="container-lg">
        <div class="row align-items-center g-4">
            <div class="col-12 col-lg-7">
                <h2 class="fw-bold">@C("home.procta.title", "Voce e profissional?")</h2>
                <p class="text-secondary-emphasis">
                    @C("home.procta.subtitle", "Cadastre-se no ConsertaPraMim e receba novas oportunidades todos os dias na sua cidade.")
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn cpm-btn-primary" asp-controller="Home" asp-action="RegisterProfessional">@C("home.procta.button_primary", "Quero me cadastrar")</a>
                    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="RegisterProfessional">@C("home.procta.button_secondary", "Saiba mais")</a>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <img src="@C("home.procta.image_url", Url.Content("~/images/7237a130-fa5b-4e98-9118-ed5b0d465fa6.png"))" alt="@C("home.procta.image_alt", "Profissional trabalhando")" class="img-fluid rounded-4 shadow" />
            </div>
        </div>
    </div>
</section>

<section class="py-5 text-center" style="background: var(--cpm-primary); color: #fff;">
    <div class="container-lg py-4">
        <h2 class="fw-bold mb-3">@C("home.finalcta.title", "Pronto para resolver seu problema?")</h2>
        <p class="mb-4">@C("home.finalcta.subtitle", "Solicite agora e receba contatos de profissionais proximos.")</p>
        <a class="btn btn-dark btn-lg" asp-controller="Home" asp-action="RequestService">@C("home.finalcta.button", "Solicitar servico agora")</a>
    </div>
</section>

@section Head {
    @{
        var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
        var itemListElements = Model.Categories
            .Select((category, idx) => new Dictionary<string, object?>
            {
                ["@type"] = "ListItem",
                ["position"] = idx + 1,
                ["name"] = category.Name,
                ["url"] = $"{baseUrl}/solicitar-servico?categoryId={category.Id}"
            })
            .ToList();

        var structuredData = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "WebPage",
                ["name"] = C("home.schema.webpage.name", pageTitle),
                ["description"] = C("home.schema.webpage.description", "Solicite servicos residenciais no ConsertaPraMim e encontre profissionais perto de voce."),
                ["url"] = $"{baseUrl}/",
                ["inLanguage"] = "pt-BR"
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "ItemList",
                ["name"] = C("home.schema.itemlist.name", C("home.topservices.title", "Servicos mais buscados")),
                ["itemListElement"] = itemListElements
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "HowTo",
                ["name"] = C("home.schema.howto.name", "Como funciona a plataforma ConsertaPraMim"),
                ["step"] = new object[]
                {
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = C("home.schema.howto.step1.name", C("home.howitworks.step1.title", "Cliente solicita o servico")), ["text"] = C("home.schema.howto.step1.text", "Descreva o problema e informe seu CEP.") },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = C("home.schema.howto.step2.name", C("home.howitworks.step2.title", "Prestadores recebem o pedido")), ["text"] = C("home.schema.howto.step2.text", "Profissionais da regiao visualizam sua solicitacao.") },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = C("home.schema.howto.step3.name", C("home.howitworks.step3.title", "Profissional envia orcamento")), ["text"] = C("home.schema.howto.step3.text", "Os interessados retornam com proposta e prazo.") },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = C("home.schema.howto.step4.name", "Cliente conversa e fecha"), ["text"] = C("home.schema.howto.step4.text", "Cliente e profissional alinham valor e agendamento.") },
                    new Dictionary<string, object?> { ["@type"] = "HowToStep", ["name"] = C("home.schema.howto.step5.name", "Servico concluido e avaliado"), ["text"] = C("home.schema.howto.step5.text", "Apos o atendimento, ambos podem avaliar a experiencia.") }
                }
            }
        };
    }
    <script type="application/ld+json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(structuredData))</script>
}

@section Scripts {
    <script>
        (() => {
            const locationInput = document.getElementById("homeLocationInput");
            const locationButton = document.getElementById("getUserLocationBtn");
            const feedback = document.getElementById("homeLocationFeedback");
            const messages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new
            {
                loading = C("home.hero.cep.loading", "Consultando CEP..."),
                resolvedTemplate = C("home.hero.cep.resolved_template", "Endereco do CEP: {address}"),
                unresolved = C("home.hero.cep.unresolved", "Nao foi possivel resolver rua, bairro, cidade e UF. O CEP digitado sera aceito."),
                geolocationUnsupported = C("home.hero.location.unsupported", "Seu navegador nao suporta geolocalizacao."),
                geolocationLoading = C("home.hero.location.loading", "Obtendo sua localizacao..."),
                cepNotIdentified = C("home.hero.location.cep_not_identified", "Nao foi possivel identificar o CEP automaticamente."),
                reverseFailed = C("home.hero.location.reverse_failed", "Nao foi possivel converter sua localizacao em CEP."),
                denied = C("home.hero.location.denied", "Permissao negada para acessar sua localizacao."),
                unavailable = C("home.hero.location.unavailable", "Localizacao indisponivel no momento."),
                timeout = C("home.hero.location.timeout", "Tempo excedido ao buscar sua localizacao."),
                genericError = C("home.hero.location.generic_error", "Nao foi possivel obter sua localizacao.")
            }));

            if (!locationInput || !locationButton || !feedback || !window.CepResolver) {
                return;
            }

            const cepLookup = window.CepResolver.bindCepLookup({
                input: locationInput,
                feedback: feedback,
                messages: {
                    loading: messages.loading,
                    resolved: (addressText) => messages.resolvedTemplate.replace("{address}", addressText),
                    unresolved: messages.unresolved
                }
            });

            const reverseGeocodeToCep = async (lat, lon) => {
                const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lon}`;
                const response = await fetch(url);
                if (!response.ok) {
                    throw new Error("reverse-geocode-failed");
                }

                const data = await response.json();
                const cepDigits = window.CepResolver.onlyDigits(data?.address?.postcode ?? "").slice(0, 8);
                return cepDigits.length === 8 ? cepDigits : null;
            };

            locationButton.addEventListener("click", () => {
                if (!navigator.geolocation) {
                    cepLookup.setFeedback("error", messages.geolocationUnsupported);
                    return;
                }

                locationButton.disabled = true;
                cepLookup.setFeedback("", messages.geolocationLoading);

                navigator.geolocation.getCurrentPosition(
                    async (position) => {
                        const latitude = position.coords.latitude.toFixed(6);
                        const longitude = position.coords.longitude.toFixed(6);

                        try {
                            const cepDigits = await reverseGeocodeToCep(latitude, longitude);
                            if (!cepDigits) {
                                cepLookup.setFeedback("warning", messages.cepNotIdentified);
                            } else {
                                locationInput.value = window.CepResolver.formatCep(cepDigits);
                                await cepLookup.lookupCurrent();
                            }
                        } catch {
                            cepLookup.setFeedback("warning", messages.reverseFailed);
                        } finally {
                            locationButton.disabled = false;
                        }
                    },
                    (error) => {
                        let message = messages.genericError;

                        if (error.code === 1) {
                            message = messages.denied;
                        } else if (error.code === 2) {
                            message = messages.unavailable;
                        } else if (error.code === 3) {
                            message = messages.timeout;
                        }

                        cepLookup.setFeedback("error", message);
                        locationButton.disabled = false;
                    },
                    {
                        enableHighAccuracy: true,
                        timeout: 10000,
                        maximumAge: 60000
                    });
            });
        })();
    </script>
}
