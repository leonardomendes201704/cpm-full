@model RegisterProfessionalSuccessViewModel
@{
    ViewData["Title"] = "Cadastro realizado com sucesso";
    ViewData["MetaDescription"] = "Confirmacao de cadastro de profissional no ConsertaPraMim.";
    ViewData["CanonicalPath"] = "/cadastro-profissional/sucesso";
    ViewData["Robots"] = "noindex,nofollow,noarchive";
}

<section class="cpm-section">
    <div class="container-lg cpm-form-wrap">
        <div class="cpm-card cpm-form-card p-4 p-md-5 bg-white text-center">
            <div class="mb-3">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3rem;"></i>
            </div>
            <h1 class="fw-bold mb-3">Cadastro realizado com sucesso</h1>
            <p class="lead mb-2">Seja bem-vindo, <strong>@Model.ProfessionalName</strong>!</p>
            <p class="text-secondary-emphasis mb-4">
                Seu perfil foi recebido e em breve voce comecara a receber novas oportunidades de servico.
            </p>
            <div class="d-flex flex-column flex-md-row justify-content-center gap-2">
                <a class="btn cpm-btn-primary" asp-controller="Home" asp-action="Index">Ir para a pagina inicial</a>
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Professionals">Ver profissionais</a>
            </div>
        </div>
    </div>
</section>
